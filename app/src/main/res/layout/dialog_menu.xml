<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="350dp"
    android:layout_height="wrap_content"
    android:background="@drawable/shape_dialog_menu_bg"
    android:orientation="vertical"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/bt_stop"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:background="#f10"
            android:text="停止触控"
            android:textColor="#fff"
            android:textSize="15sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:visibility="visible" />

        <Button
            android:id="@+id/bt_add"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="1dp"
            android:layout_weight="1"
            android:background="#666"
            android:text="添加触控点"
            android:textColor="#fff"
            android:textSize="15sp" />

        <Button
            android:id="@+id/bt_reply"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="1dp"
            android:layout_weight="1"
            android:background="#666"
            android:text="回复话术"
            android:textColor="#fff"
            android:textSize="15sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/bt_exit"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginStart="1dp"
            android:layout_weight="1"
            android:background="#666"
            android:text="退出助手"
            android:textColor="#fff"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- 福袋方案选择器行（仅福袋模式可见）—— 三个固定按钮 -->
    <LinearLayout
        android:id="@+id/ll_scheme_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:visibility="gone"
        tools:visibility="visible">

        <Button
            android:id="@+id/bt_scheme_1"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:background="#666"
            android:text="方案一"
            android:textColor="#fff"
            android:textSize="14sp" />

        <Button
            android:id="@+id/bt_scheme_2"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="#666"
            android:text="方案二"
            android:textColor="#fff"
            android:textSize="14sp" />

        <Button
            android:id="@+id/bt_scheme_3"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:background="#666"
            android:text="方案三"
            android:textColor="#fff"
            android:textSize="14sp" />

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="触控点列表"
        android:textSize="18sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="#ccc" />

    <Button
        android:id="@+id/bt_lucky_bag_start"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:background="#4CAF50"
        android:text="开始抢福袋"
        android:textColor="#fff"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

</LinearLayout>
