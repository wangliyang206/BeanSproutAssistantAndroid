<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- 主应用主题 -->
    <style name="Theme.MyApplication" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- 启动页主题 -->
    <style name="Theme.SplashDemo.Splash" parent="Theme.MyApplication">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <style name="Theme.JetpackCompose" parent="Theme.SplashScreen">
        <!-- 闪屏背景色 -->
        <item name="windowSplashScreenBackground">@color/black</item>
        <!-- 闪屏图标（支持静态或动画矢量图） -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/icon_splash_screen</item>
        <!-- 图标动画时长 -->
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <!-- 可选：图标背景色（如果图片有透明区域，可设置此色作为底色） -->
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <!-- 状态栏字体颜色为深色 -->
        <item name="android:windowLightStatusBar">true</item>
        <!-- 主应用主题（启动页结束后切换到的主题） -->
        <!--<item name="postSplashScreenTheme">@style/Theme.MyApplication</item>-->
    </style>
</resources>